# Application
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
APP_NAME=Lower-AIGC
APP_URL=http://localhost:5173

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/lower_aigc.db

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Email (SMTP) - leave SMTP_PASSWORD empty to use console mode in development
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REQUIRE_EMAIL_VERIFICATION=true
ADMIN_EMAILS=["example@example.com"]

# Upload
MAX_UPLOAD_SIZE_MB=16
MAX_PARAGRAPHS_PER_DOC=500
